{
  "name": "pi-do-eval",
  "version": "0.2.0",
  "description": "General-purpose eval framework for Pi extensions",
  "type": "module",
  "exports": {
    ".": "./src/lib/eval/index.ts",
    "./server/config": "./src/lib/server/config.ts"
  },
  "bin": {
    "pi-do-eval": "./cli/index.ts"
  },
  "files": [
    "build",
    "cli",
    "src",
    "LICENSE",
    "README.md",
    "package.json",
    "svelte.config.js",
    "tsconfig.json",
    "vite.config.ts"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "prepack": "npm run build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "lint": "biome check",
    "lint:fix": "biome check --write"
  },
  "dependencies": {
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@sveltejs/adapter-node": "^5.2.12",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "bits-ui": "^2.17.3",
    "clsx": "^2.1.1",
    "jsdom": "^29.0.2",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.0",
    "vite": "^8.0.7",
    "vitest": "^3.2.1"
  },
  "license": "MIT"
}
